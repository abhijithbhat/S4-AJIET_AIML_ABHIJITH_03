class Main {
    public static void main(String[] args) {
        int[] arr = {1,2,3,499,76,23,45,34,55,90};
        
        int max = arr[0];
        
        for(int i=0;i<arr.length;i++){
            if(  arr[i]>max){
                max = arr[i];
            }
        }
        System.out.println("Maximum value in array is "+ max);
    }
}
