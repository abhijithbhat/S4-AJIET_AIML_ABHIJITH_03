class Main {
    public static void main(String[] args) {
        int[] arr = {0,1,2,3,499,76,23,45,34,55,90,-1};
        
        int min = arr[0];
        
        for(int i=0;i<arr.length;i++){
            if(  arr[i]<min){
                min = arr[i];
            }
        }
        System.out.println("Minimum value in array is "+ min);
    }
}
